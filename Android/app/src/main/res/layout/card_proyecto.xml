<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardProyecto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    android:backgroundTint="?attr/colorSurface"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Imagen del proyecto -->
        <ImageView
            android:id="@+id/imgLogoEmpresa"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:scaleType="centerCrop"
            android:src="@drawable/solinx_logo"
            android:contentDescription="Imagen Proyecto"
            android:background="@color/brand_light"
            android:layout_marginBottom="12dp" />

        <!-- Badge de estado solicitud -->
        <TextView
            android:id="@+id/txtEstadoSolicitud"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏳ En proceso"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_badge_yellow"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <!-- Nombre del proyecto -->
        <TextView
            android:id="@+id/txtNombreProyecto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre Proyecto"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <!-- Empresa -->
        <TextView
            android:id="@+id/txtNombreEmpresa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre Empresa"
            android:textColor="?attr/colorPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <!-- Meta: carrera y vacantes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/txtRepresentante"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Carrera"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/txtVacantes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 vacantes"
                android:textColor="?attr/colorPrimary"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Fechas -->
        <TextView
            android:id="@+id/txtFechas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha: DD/MM/YYYY - DD/MM/YYYY"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp"
            android:layout_marginBottom="10dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutline"
            android:alpha="0.3"
            android:layout_marginBottom="10dp"/>

        <!-- CTA -->
        <TextView
            android:id="@+id/txtVerDetalles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ver detalles →"
            android:textColor="?attr/colorPrimary"
            android:textSize="13sp"
            android:textStyle="bold"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>