<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:backgroundTint="?attr/colorSurface"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Imagen del proyecto -->
        <ImageView
            android:id="@+id/imgProyecto"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:scaleType="centerCrop"
            android:src="@drawable/img_default_proyecto"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Badge estado + acciones -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvEstadoProyecto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏳ En revisión"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/bg_badge_rounded"
                    android:backgroundTint="#D69E2E"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvIdProyecto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="#001"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginEnd="8dp"/>

                <ImageView
                    android:id="@+id/btnEditar"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/edit"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tvEliminar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:textSize="16sp"
                    android:textColor="@color/color_eliminar"
                    android:textStyle="bold"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- Nombre del proyecto -->
            <TextView
                android:id="@+id/tvNombreProyecto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="Sistema de Gestión Escolar"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="2dp"/>

            <!-- Empresa -->
            <TextView
                android:id="@+id/tvNombreEmpresa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="TechNova Solutions"
                android:textSize="13sp"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutline"
                android:alpha="0.2"
                android:layout_marginBottom="8dp"/>

            <!-- Carrera -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carrera: "
                    android:textSize="13sp"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvCarreraEnfocada"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    tools:text="Ingeniería en Software"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface"/>
            </LinearLayout>

            <!-- Vacantes + Ubicación -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vacantes: "
                    android:textSize="13sp"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvVacantes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    tools:text="3"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ubicación: "
                    android:textSize="13sp"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvUbicacion"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    tools:text="CDMX"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface"/>
            </LinearLayout>

            <!-- Fechas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">
                <TextView
                    android:id="@+id/tvFechaInicio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    tools:text="Inicio: 01/01/2026"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"/>
                <TextView
                    android:id="@+id/tvFechaFin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    tools:text="Fin: 30/06/2026"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"/>
            </LinearLayout>

            <!-- Objetivo -->
            <TextView
                android:id="@+id/tvObjetivo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="Desarrollar un sistema web moderno..."
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="4dp"/>

            <!-- Apoyo (oculto si está vacío) -->
            <TextView
                android:id="@+id/tvApoyo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Apoyo: Beca"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:visibility="gone"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>