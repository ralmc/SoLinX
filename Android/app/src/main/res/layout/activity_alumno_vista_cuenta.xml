<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_vcalumno"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground"
    android:fitsSystemWindows="true"
    tools:context=".AlumnoVistaCuenta">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="50dp">

            <!-- HEADER -->
            <LinearLayout
                android:id="@+id/header_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="40dp"
                android:paddingHorizontal="24dp">

                <ImageButton
                    android:id="@+id/regresar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/flechaizq"
                    android:background="@android:color/transparent"
                    android:scaleType="fitCenter"
                    android:contentDescription="Regresar"
                    app:tint="@color/flecha_color"/>

                <ImageView
                    android:id="@+id/imgLogoAve"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/solinx_logo"
                    android:scaleType="fitCenter"
                    android:contentDescription="Logo SoLinX" />

                <Space android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="12dp">
                    <TextView
                        android:id="@+id/tvBoleta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2023XXXXXX"
                        android:textSize="18sp"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/imgPerfil"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/imagen_prederterminada"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Foto de perfil"/>
            </LinearLayout>

            <!-- BARRA SEPARADORA -->
            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="24dp"
                android:background="?attr/colorPrimary" />

            <!-- ALERTA CAMBIOS PENDIENTES -->
            <TextView
                android:id="@+id/tvAlertaPendiente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:padding="12dp"
                android:background="#FFF3CD"
                android:textColor="#856404"
                android:textSize="13sp"
                android:text="⏳ Cambios en revisión por el supervisor"
                android:visibility="gone"
                android:drawablePadding="8dp"/>

            <!-- SELECTOR DE MODO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp"
                android:paddingHorizontal="24dp">

                <TextView
                    android:id="@+id/tvModo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Modo"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <View
                        android:id="@+id/viewModoClaro"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/circle_light"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="12dp" />

                    <View
                        android:id="@+id/viewModoOscuro"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/circle_dark"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginStart="12dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- SECCIÓN: INFORMACIÓN DEL ALUMNADO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Información del alumnado"
                android:textColor="?attr/colorPrimary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp" />

            <!-- Nombre -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre: "
                    android:textColor="?attr/colorPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvNombre"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cargando..."
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/btnEditarNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️"
                    android:textSize="18sp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"/>
            </LinearLayout>

            <!-- Correo (solo lectura) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Correo: "
                    android:textColor="?attr/colorPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvCorreo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cargando..."
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="16sp"/>
            </LinearLayout>

            <!-- Escuela -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Escuela: "
                    android:textColor="?attr/colorPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvEscuela"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cargando..."
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/btnEditarEscuela"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️"
                    android:textSize="18sp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"/>
            </LinearLayout>

            <!-- Carrera -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carrera: "
                    android:textColor="?attr/colorPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvCarrera"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cargando..."
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/btnEditarCarrera"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️"
                    android:textSize="18sp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"/>
            </LinearLayout>

            <!-- SECCIÓN: STATUS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status de solicitudes"
                android:textColor="?attr/colorPrimary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="24dp" />

            <TextView
                android:id="@+id/tvPuntosStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cargando solicitudes..."
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp" />

            <!-- SECCIÓN: HORARIO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mi Horario"
                android:textColor="?attr/colorPrimary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="24dp"
                android:layout_marginTop="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                android:background="?attr/colorPrimary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp">

                <!-- LUNES -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingVertical="10dp">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:text="Lunes" android:textColor="?attr/colorPrimary"
                        android:textStyle="bold" android:textSize="15sp"/>
                    <TextView android:id="@+id/tvHorarioLunes" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Sin clase" android:textColor="?android:attr/textColorSecondary"
                        android:textSize="15sp"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="?attr/colorPrimary" android:alpha="0.15"/>

                <!-- MARTES -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingVertical="10dp">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:text="Martes" android:textColor="?attr/colorPrimary"
                        android:textStyle="bold" android:textSize="15sp"/>
                    <TextView android:id="@+id/tvHorarioMartes" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Sin clase" android:textColor="?android:attr/textColorSecondary"
                        android:textSize="15sp"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="?attr/colorPrimary" android:alpha="0.15"/>

                <!-- MIÉRCOLES -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingVertical="10dp">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:text="Miércoles" android:textColor="?attr/colorPrimary"
                        android:textStyle="bold" android:textSize="15sp"/>
                    <TextView android:id="@+id/tvHorarioMiercoles" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Sin clase" android:textColor="?android:attr/textColorSecondary"
                        android:textSize="15sp"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="?attr/colorPrimary" android:alpha="0.15"/>

                <!-- JUEVES -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingVertical="10dp">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:text="Jueves" android:textColor="?attr/colorPrimary"
                        android:textStyle="bold" android:textSize="15sp"/>
                    <TextView android:id="@+id/tvHorarioJueves" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Sin clase" android:textColor="?android:attr/textColorSecondary"
                        android:textSize="15sp"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="?attr/colorPrimary" android:alpha="0.15"/>

                <!-- VIERNES -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingVertical="10dp">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:text="Viernes" android:textColor="?attr/colorPrimary"
                        android:textStyle="bold" android:textSize="15sp"/>
                    <TextView android:id="@+id/tvHorarioViernes" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Sin clase" android:textColor="?android:attr/textColorSecondary"
                        android:textSize="15sp"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="?attr/colorPrimary" android:alpha="0.15"/>

                <!-- SÁBADO -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingVertical="10dp">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:text="Sábado" android:textColor="?attr/colorPrimary"
                        android:textStyle="bold" android:textSize="15sp"/>
                    <TextView android:id="@+id/tvHorarioSabado" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Sin clase" android:textColor="?android:attr/textColorSecondary"
                        android:textSize="15sp"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="?attr/colorPrimary" android:alpha="0.15"/>

                <!-- DOMINGO -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingVertical="10dp">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:text="Domingo" android:textColor="?attr/colorPrimary"
                        android:textStyle="bold" android:textSize="15sp"/>
                    <TextView android:id="@+id/tvHorarioDomingo" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Sin clase" android:textColor="?android:attr/textColorSecondary"
                        android:textSize="15sp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- CONTACTAR SOPORTE -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:layout_marginBottom="8dp"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/colorPrimary" android:alpha="0.2"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/btnContactarSoporte"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✉  Contactar Soporte"
            android:textSize="16sp"
            android:textColor="?attr/colorSecondary"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingVertical="14dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¿Necesitas ayuda? Envía un correo al supervisor"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>
    </LinearLayout>

    <!-- FOOTER: CERRAR SESIÓN -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:layout_marginBottom="24dp"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <Button
            android:id="@+id/btnCerrarSesion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cerrar Sesión"
            android:textColor="?attr/colorPrimary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="@font/molgan"
            android:background="@android:color/transparent"
            android:padding="8dp"/>

        <View
            android:layout_width="180dp"
            android:layout_height="3dp"
            android:background="?attr/colorPrimary" />
    </LinearLayout>
</LinearLayout>