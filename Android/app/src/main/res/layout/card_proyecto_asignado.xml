<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollProyectoAsignado"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Mensaje de felicitaciones -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎉 ¡Felicidades! Ya perteneces a este proyecto"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:padding="12dp"
            android:background="?attr/colorSurfaceVariant" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imgProyectoAsignado"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_default_proyecto"
                    android:contentDescription="Imagen del proyecto" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvNombreProyectoAsignado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nombre del Proyecto"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvEmpresaAsignado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Empresa: "
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvCarreraAsignado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Carrera enfocada: "
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvUbicacionAsignado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ubicación: "
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvFechaInicioAsignado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fecha de inicio: "
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvFechaFinAsignado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fecha de término: "
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvTelefonoAsignado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Teléfono: "
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Objetivo:"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvObjetivoAsignado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="..."
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="16dp" />

                    <Button
                        android:id="@+id/btnContactarEmpresa"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✉ Contactar Empresa"
                        android:textColor="?attr/colorOnPrimary"
                        android:backgroundTint="?attr/colorPrimary"
                        android:padding="12dp"
                        android:textStyle="bold" />

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
