<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">
            <!-- ─── SECCIÓN: Formatos para descargar ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Formatos para descargar"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descárgalos, llénalos, fírmalos y súbelos abajo"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"/>

            <!-- Cards de formatos -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/cardGuiaLlenado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="10dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="36dp" android:layout_height="36dp"
                        android:text="📋" android:textSize="20sp" android:gravity="center"
                        android:background="@color/brand_light" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Guía de llenado de reportes"
                            android:textSize="14sp" android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Instrucciones paso a paso"
                            android:textSize="12sp" android:textColor="?android:attr/textColorSecondary"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PDF" android:textSize="11sp" android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/cardReporteMensual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="10dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="36dp" android:layout_height="36dp"
                        android:text="📄" android:textSize="20sp" android:gravity="center"
                        android:background="@color/brand_light" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Reporte Mensual de Actividades"
                            android:textSize="14sp" android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Formato oficial IPN — se entrega cada mes"
                            android:textSize="12sp" android:textColor="?android:attr/textColorSecondary"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PDF" android:textSize="11sp" android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardControlAsistencia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="10dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/brand_light"
                        android:gravity="center"
                        android:text="📄"
                        android:textSize="20sp" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Control de Asistencia"
                            android:textSize="14sp" android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Registro diario — se entrega con el reporte mensual"
                            android:textSize="12sp" android:textColor="?android:attr/textColorSecondary"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PDF" android:textSize="11sp" android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/cardReporteGlobal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="10dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="36dp" android:layout_height="36dp"
                        android:text="📝" android:textSize="20sp" android:gravity="center"
                        android:background="@color/brand_light" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Reporte Global de Actividades"
                            android:textSize="14sp" android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Resumen final de toda la prestación (3 cuartillas)"
                            android:textSize="12sp" android:textColor="?android:attr/textColorSecondary"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PDF" android:textSize="11sp" android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/cardEvaluacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="10dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="36dp" android:layout_height="36dp"
                        android:text="📝" android:textSize="20sp" android:gravity="center"
                        android:background="@color/brand_light" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Formato de Evaluación"
                            android:textSize="14sp" android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Lo llena tu Responsable Directo"
                            android:textSize="12sp" android:textColor="?android:attr/textColorSecondary"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PDF" android:textSize="11sp" android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutline"
                android:alpha="0.3"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"/>

            <!-- ─── SECCIÓN: Mis Reportes ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mis Reportes"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sube tus reportes firmados de cada período (PDF, máx. 1.5 MB)"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerPeriodos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>