<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:layout_marginBottom="12dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Botón expandir -->
        <ImageButton
            android:id="@+id/btn_expandir_detalles"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_down"
            android:contentDescription="Ver más"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Info siempre visible -->
        <LinearLayout
            android:id="@+id/layout_resumen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_expandir_detalles">

            <TextView
                android:id="@+id/tv_nombre_alumno"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre Alumno"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_correo_alumno"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="correo@ejemplo.com"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_carrera_alumno"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Carrera: N/A"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"/>
        </LinearLayout>

        <!-- Info expandible -->
        <LinearLayout
            android:id="@+id/layout_detalles_expandibles"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:paddingTop="10dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="8dp"
            android:background="?attr/colorSurfaceVariant"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/layout_resumen"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_nombre_empresa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Empresa: N/A"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_nombre_proyecto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Proyecto: N/A"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_fecha_aceptacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aceptado: N/A"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>