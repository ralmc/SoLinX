<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground"
    android:fitsSystemWindows="true"
    tools:context=".EmpresaNotificaciones">

    <!-- TOPBAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/colorSurface"
        android:elevation="2dp">

        <ImageView
            android:id="@+id/logoEmpresa"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/solinx_logo"
            android:scaleType="fitCenter"
            android:contentDescription="Logo SoLinX"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="SoLinX"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:id="@+id/btnMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Proyectos"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:background="?android:attr/textColorSecondary"
            android:alpha="0.3"/>

        <TextView
            android:id="@+id/btnNoti"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Solicitudes"
            android:textSize="14sp"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"/>

        <ImageView
            android:id="@+id/imgPerfilEmpresa"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/imagen_prederterminada"
            android:scaleType="centerCrop"
            android:contentDescription="Perfil"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- DIVIDER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutline"
        android:alpha="0.3"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Solicitudes Recibidas"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:id="@+id/contenedorNotificaciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <TextView
                android:id="@+id/tvMensajeVacio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sin solicitudes nuevas por ahora 📭"
                android:textSize="15sp"
                android:textColor="?android:attr/textColorSecondary"
                android:gravity="center"
                android:layout_marginTop="48dp"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>