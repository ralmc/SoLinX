<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:layout_marginBottom="10dp"
    android:backgroundTint="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Fila superior: nombre + flecha -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_nombre_alumno"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre Alumno"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/tv_correo_alumno"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="correo@ejemplo.com"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_expandir_detalles"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_arrow_down"
                android:contentDescription="Ver más detalles"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"/>
        </LinearLayout>

        <!-- Carrera siempre visible -->
        <TextView
            android:id="@+id/tv_carrera_alumno"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Carrera: Ingeniería en Software"
            android:textSize="13sp"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"/>

        <!-- Detalles expandibles -->
        <LinearLayout
            android:id="@+id/layout_detalles_expandibles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="10dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutline"
                android:alpha="0.2"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tv_carrera_enfocada"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carrera enfocada: N/A"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_nombre_proyecto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Proyecto: N/A"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_nombre_empresa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Empresa: N/A"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutline"
            android:alpha="0.2"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"/>

        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btn_enviar_correo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✉ Correo"
                android:textSize="13sp"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/btn_rechazar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕ Rechazar"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_badge_rounded"
                android:backgroundTint="@color/color_rechazar"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btn_aprobar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ Aprobar"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_badge_rounded"
                android:backgroundTint="@color/color_aprobar"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>