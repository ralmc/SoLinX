<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:layout_marginBottom="12dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Botón expandir (flecha) -->
        <ImageButton
            android:id="@+id/btn_expandir_detalles"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_down"
            android:contentDescription="Ver más detalles"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ─── Info siempre visible ─────────────────────────── -->
        <LinearLayout
            android:id="@+id/layout_resumen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_expandir_detalles">

            <!-- Nombre alumno en grande -->
            <TextView
                android:id="@+id/tv_nombre_alumno"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre Alumno"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="4dp"/>

            <!-- Correo -->
            <TextView
                android:id="@+id/tv_correo_alumno"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="correo@ejemplo.com"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="4dp"/>

            <!-- Carrera del alumno -->
            <TextView
                android:id="@+id/tv_carrera_alumno"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Carrera: Ingeniería en Software"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"/>
        </LinearLayout>

        <!-- ─── Info expandible ──────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layout_detalles_expandibles"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:paddingTop="10dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="?attr/colorSurfaceVariant"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/layout_resumen"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_carrera_enfocada"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Carrera enfocada: N/A"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_nombre_proyecto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Proyecto: N/A"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_nombre_empresa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Empresa: N/A"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="10dp"/>
        </LinearLayout>

        <!-- ─── Botones ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/layout_detalles_expandibles"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/btn_enviar_correo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✉ Correo"
                android:textSize="15sp"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/btn_rechazar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rechazar"
                android:textSize="15sp"
                android:textColor="@color/color_rechazar"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:layout_marginEnd="12dp"
                android:background="?attr/selectableItemBackground"/>

            <TextView
                android:id="@+id/btn_aprobar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aprobar"
                android:textSize="15sp"
                android:textColor="@color/color_aprobar"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>