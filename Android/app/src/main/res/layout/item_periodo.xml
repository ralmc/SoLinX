<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_periodo_card">

    <!-- Fila superior: número de periodo + badge estado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvPeriodo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Periodo 1"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/molgan"/>

        <!-- Badge de estado (aprobado / rechazado / en revisión) -->
        <TextView
            android:id="@+id/tvEstadoBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏳ En revisión"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:backgroundTint="#D69E2E"
            android:background="@drawable/bg_badge_rounded"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Nombre archivo / estado -->
    <TextView
        android:id="@+id/tvEstado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="?android:attr/textColorSecondary"
        android:layout_marginBottom="8dp"
        android:visibility="gone"/>

    <!-- Botón subir/resubir -->
    <Button
        android:id="@+id/btnSubir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Subir PDF"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1497B9"
        android:visibility="visible"/>

    <!-- Previa antes de confirmar -->
    <LinearLayout
        android:id="@+id/layoutPrevia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvNombreArchivo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📄 archivo.pdf"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btnCambiar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cambiar"
                android:backgroundTint="@android:color/transparent"
                android:textColor="?attr/colorPrimary"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnConfirmar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirmar ✓"
                android:backgroundTint="#1497B9"
                android:textColor="#FFFFFF"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>