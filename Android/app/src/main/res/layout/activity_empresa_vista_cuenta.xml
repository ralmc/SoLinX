<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_vcempresa"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground"
    android:fitsSystemWindows="true"
    tools:context=".EmpresaVistaCuenta">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ─── TOPBAR ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:background="?attr/colorSurface"
                android:elevation="2dp">

                <ImageButton
                    android:id="@+id/regresar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/flechaizq"
                    android:background="@android:color/transparent"
                    android:scaleType="fitCenter"
                    android:contentDescription="Regresar"
                    app:tint="@color/flecha_color"/>

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="10dp"
                    android:src="@drawable/solinx_logo"
                    android:scaleType="fitCenter"
                    android:contentDescription="Logo SoLinX"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Mi Perfil"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tvNombrePersona"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre"
                    android:textSize="13sp"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:maxWidth="120dp"
                    android:layout_marginEnd="12dp"/>

                <ImageView
                    android:id="@+id/imgPerfil"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/imagen_prederterminada"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Foto de perfil"/>
            </LinearLayout>

            <!-- DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutline"
                android:alpha="0.3"/>

            <!-- ─── ALERTA CAMBIOS PENDIENTES ─── -->
            <TextView
                android:id="@+id/tvAlertaPendiente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:padding="12dp"
                android:background="@color/color_warning_bg"
                android:textColor="@color/color_warning_text"
                android:textSize="13sp"
                android:text="⏳ Cambios en revisión por el supervisor"
                android:visibility="gone"/>

            <!-- ─── MODO (TEMA) ─── -->
            <androidx.cardview.widget.CardView
                xmlns:app2="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app2:cardCornerRadius="12dp"
                app2:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tema"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <View
                        android:id="@+id/viewModoClaro"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/circle_light"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="12dp"/>

                    <View
                        android:id="@+id/viewModoOscuro"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/circle_dark"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ─── INFORMACIÓN DE LA EMPRESA ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Información de la empresa"
                android:textColor="?attr/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                xmlns:app3="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app3:cardCornerRadius="12dp"
                app3:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Nombre -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nombre"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="12sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvNombre"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cargando..."
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="15sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/btnEditarNombre"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✏️"
                            android:textSize="18sp"
                            android:padding="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="?attr/colorOutline" android:alpha="0.2"
                        android:layout_marginHorizontal="16dp"/>

                    <!-- Correo (solo lectura) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Correo"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="12sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvCorreo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cargando..."
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="15sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="?attr/colorOutline" android:alpha="0.2"
                        android:layout_marginHorizontal="16dp"/>

                    <!-- Teléfono -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Teléfono"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="12sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvTelefono"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cargando..."
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="15sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/btnEditarTelefono"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✏️"
                            android:textSize="18sp"
                            android:padding="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- ─── FOOTER ─── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="24dp"
        android:paddingTop="12dp"
        android:background="?attr/colorSurface">

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/colorOutline" android:alpha="0.2"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnContactarSoporte"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✉  Contactar Soporte"
            android:textSize="14sp"
            android:textColor="?attr/colorPrimary"
            android:backgroundTint="@android:color/transparent"
            android:layout_marginBottom="8dp"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btnCerrarSesion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cerrar Sesión"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/color_rechazar"
            style="@style/Widget.Material3.Button"/>

    </LinearLayout>
</LinearLayout>