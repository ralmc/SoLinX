<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AlumnoHorario">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginTop="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/molgan"
            android:text="Registrar Horario"
            android:textColor="#000000"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- LUNES -->
        <include layout="@layout/item_dia_horario"
            android:id="@+id/diaLunes" />

        <!-- MARTES -->
        <include layout="@layout/item_dia_horario"
            android:id="@+id/diaMartes" />

        <!-- MIÉRCOLES -->
        <include layout="@layout/item_dia_horario"
            android:id="@+id/diaMiercoles" />

        <!-- JUEVES -->
        <include layout="@layout/item_dia_horario"
            android:id="@+id/diaJueves" />

        <!-- VIERNES -->
        <include layout="@layout/item_dia_horario"
            android:id="@+id/diaViernes" />

        <!-- SABADO -->
        <include layout="@layout/item_dia_horario"
            android:id="@+id/diaSabado" />

        <!-- DOMINGO -->
        <include layout="@layout/item_dia_horario"
            android:id="@+id/diaDomingo" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginVertical="16dp">

            <Button
                android:id="@+id/btnEnviarHorario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="32dp"
                android:text="Enviar"
                android:textColor="#000000"
                android:textSize="36sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:backgroundTint="@android:color/transparent"
                android:fontFamily="@font/molgan" />

            <View
                android:layout_width="200dp"
                android:layout_height="5dp"
                android:background="#000000"
                android:layout_marginTop="1dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>