<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:backgroundTint="?attr/colorSurface"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Fila superior: número + estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvNumeroSolicitud"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                tools:text="Solicitud #1"
                android:text="Cargando..."
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/tvEstadoSolicitud"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="⏳ Pendiente"
                android:textColor="@color/color_estado_pendiente"
                android:textStyle="bold"
                android:textSize="12sp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_badge_rounded"
                android:backgroundTint="@color/color_estado_pendiente_bg"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutline"
            android:alpha="0.2"
            android:layout_marginBottom="10dp"/>

        <!-- Fila: foto + info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imgFotoEstudiante"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:scaleType="centerCrop"
                android:src="@drawable/imagen_prederterminada"
                android:contentDescription="Foto"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNombreProyecto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Sistema de Gestión Escolar"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/tvBoleta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Boleta: 2023000001"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="13sp"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/tvCarreraAlumno"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Ingeniería en Software"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutline"
            android:alpha="0.2"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"/>

        <!-- Botones de acción -->
        <LinearLayout
            android:id="@+id/layoutBotonesAccion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/btnAdmitir"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✓ Admitir"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:background="@drawable/bg_badge_rounded"
                android:backgroundTint="@color/color_aprobar"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/btnRechazar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✕ Rechazar"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:background="@drawable/bg_badge_rounded"
                android:backgroundTint="@color/color_rechazar"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Correo -->
        <TextView
            android:id="@+id/btnEnviarCorreoAlumno"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✉ Enviar correo al alumno"
            android:textSize="13sp"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>