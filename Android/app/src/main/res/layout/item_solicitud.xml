<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:fitsSystemWindows="true"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_nombre_estudiante"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre del Estudiante"
            android:textSize="18sp"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_boleta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Boleta: 20230001"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_carrera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ingeniería en Software"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_proyecto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Proyecto: Sistema de Gestión"
            android:textSize="14sp"
            android:textColor="?attr/colorSecondary"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btn_enviar_correo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✉ Correo"
                android:textSize="14sp"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground" />

            <Button
                android:id="@+id/btn_rechazar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rechazar"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/color_rechazar"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btn_aprobar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aprobar"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/color_aprobar"
                style="@style/Widget.MaterialComponents.Button" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
