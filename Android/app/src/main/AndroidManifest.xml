<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:theme="@style/Theme.SoLinX">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_solinx_logo"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_solinx_logo_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SoLinX"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">
        <activity
            android:name=".SupervisorDocumentos"
            android:exported="false" />
        <activity
            android:name=".SupervisorProyectosActivity"
            android:exported="false"/>
        <activity
            android:name=".CONEXION.InicioHelper"
            android:exported="false" />
        <activity
            android:name=".CargaActivity"
            android:exported="true"
            android:theme="@style/Theme.SoLinX">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <activity
            android:name=".MenuSupervisorActivity"
            android:exported="true" />
        <activity
            android:name=".AlumnoEnviarSolicitud"
            android:exported="true" />
        <activity
            android:name=".AlumnoMenuEmpresas"
            android:exported="true" />
        <activity
            android:name=".EmpresaVista"
            android:exported="true" />
        <activity
            android:name=".GestionProyectoActivity"
            android:exported="false" />
        <activity
            android:name=".menu_super"
            android:exported="false" />
        <activity
            android:name=".EmpresaNotificaciones"
            android:exported="false" />
        <activity
            android:name=".AlumnoVistaCuenta"
            android:exported="false" />
        <activity
            android:name=".SupervisorVistaCuenta"
            android:exported="false" />
        <activity
            android:name=".EmpresaVistaCuenta"
            android:exported="false" />
        <activity
            android:name=".AprobarSolicitudesAlumnosActivity"
            android:exported="false" />
        <activity
            android:name=".AprobarAceptacionesEmpresaActivity"
            android:exported="false" />

        <uses-library
            android:name="org.apache.http.legacy"
            android:required="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"/>
        </provider>
    </application>
</manifest>